# ─── AI (Required for AI form generation) ─────────────────────────────────────
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── MongoDB (Optional – omit to use localStorage only) ───────────────────────
#
# When MONGODB_URI is set AND NEXT_PUBLIC_USE_MONGODB=true, all forms and
# responses are persisted in MongoDB instead of (or in addition to) localStorage.
#
# Local dev (MongoDB Community / Docker):
#   MONGODB_URI=mongodb://localhost:27017/saur-forms
#
# MongoDB Atlas:
#   MONGODB_URI=mongodb+srv://Kishore:azsxdcfv0000@cluster0.mongodb.net/saur-forms?retryWrites=true&w=majority
#
MONGODB_URI=

# Set to "true" to activate the MongoDB storage adapter.
# When "false" (default), the app works fully in localStorage — no backend required.
NEXT_PUBLIC_USE_MONGODB=false
